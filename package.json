{
  "name": "bagpipe",
  "version": "1.2.0",
  "description": "ROS bag pipeline — export ROS1/ROS2 bag files to CSV and MP4",
  "main": "electron/main.js",
  "bin": {
    "bagpipe": "./cli/index.js"
  },
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "cli": "node cli/index.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@foxglove/rosbag": "^0.4.1",
    "@foxglove/rosbag2": "^6.0.0",
    "@foxglove/rosbag2-node": "^5.0.0",
    "@mcap/core": "^2.1.7",
    "@mcap/nodejs": "^1.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0",
    "commander": "^11.0.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "xmlbuilder2": "^3.1.1",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "edu.hiro.bagpipe",
    "productName": "Bagpipe",
    "copyright": "HiRo Lab",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "electron/**/*",
      "assets/**/*",
      "cli/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.md",
      "!**/*.map"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/@foxglove/rosbag2-node/**/*",
      "node_modules/7zip-bin/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/bagpipe.ico",
      "artifactName": "Bagpipe-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/bagpipe.ico",
      "uninstallerIcon": "assets/bagpipe.ico",
      "installerHeaderIcon": "assets/bagpipe.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bagpipe",
      "license": null,
      "runAfterFinish": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/bagpipe.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "Bagpipe-${version}.dmg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/bagpipe.png",
      "category": "Science",
      "artifactName": "Bagpipe-${version}.AppImage"
    }
  }
}